PORT=4000
HOST=0.0.0.0
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars
NODE_ENV=production
GROQ_API_KEY=your-groq-api-key-here

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN_CAR=your-telegram-car-bot-token-here
TELEGRAM_BOT_TOKEN_DEBT=your-telegram-debt-bot-token-here
TELEGRAM_BOT_TOKEN_WAREHOUSE=your-telegram-warehouse-bot-token-here
ADMIN_CHAT_ID=your-admin-chat-id-here
WAREHOUSE_ADMIN_CHAT_ID=your-warehouse-admin-chat-id-here
WEBHOOK_URL=https://your-domain.com/api/telegram

# CORS & JWT
ALLOWED_ORIGINS=https://your-domain.com
JWT_EXPIRY=7d